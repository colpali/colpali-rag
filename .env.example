# colpali-rag configuration. Copy to .env and edit. Everything is optional with
# sane defaults — the tool runs with none of this set.

# --- retriever (ColPali / ColVision) ---
# Any ColVision model id. colSmol-500M runs on CPU; colqwen2-v1.0 on GPU is sharper.
# See docs/PIPELINE.md §11 for the clean CPU->GPU model ladder + the exclude list.
COLPALI_MODEL=vidore/colSmol-500M
COLPALI_DEVICE=cpu            # cpu | cuda | mps
COLPALI_BATCH_SIZE=1
# COLPALI_FAMILY=            # force a family (modernvbert|smol|qwen2|qwen2.5|qwen3|gemma|colpali) for a new checkpoint
COLPALI_DPI=150               # lower (e.g. 110) + lower MAX_DIM = faster CPU indexing (measure quality)
COLPALI_MAX_DIM=1600          # 1024 is much faster on CPU; see docs/PERFORMANCE.md
# COLPALI_INDEX_CHECKPOINT_PAGES=250   # persist the index every N pages (resumable long runs)
# --- optional domain fine-tune (PEFT/LoRA adapter over the base model) ---
# COLPALI_ADAPTER_PATH=      # adapter dir or hub id; empty = base model. A fine-tuned index can
#                            # only be queried with the same adapter (enforced by the identity guard).
# COLPALI_ADAPTER_MERGE=false # merge the adapter into base weights at load (faster inference)
# COLPALI_NORM_CHECK=true    # warn at index time if page embeddings aren't unit-norm
# COLPALI_NORM_TOL=0.001     # tolerance for that check (mean |‖E‖-1|)

# --- store ---
COLPALI_STORE=memory          # memory (zero infra) | qdrant (scale / persistence)
COLPALI_DATA_DIR=colpali_data
COLPALI_COLLECTION=documents
# For COLPALI_STORE=qdrant, point at a server; leave blank for embedded on-disk.
QDRANT_URL=
QDRANT_API_KEY=

# --- optional reranking (config-gated OFF; needs the [rerank] extra + a GPU) ---
RERANK_ENABLED=false
RERANK_BACKEND=monoqwen       # none | monoqwen  (lightonai/MonoQwen2-VL-v0.1, Apache-2.0)
RERANK_DEVICE=cuda

# --- optional answer model (vendor-neutral) ---
# Point at ANY OpenAI-compatible /chat/completions vision endpoint you run
# (self-hosted vLLM / Ollama / LM Studio / TGI, or a hosted one). Leave blank to
# disable answer generation — search + heatmaps still work with no model here.
VLM_BASE_URL=                 # e.g. http://localhost:8000/v1
VLM_API_KEY=
VLM_MODEL=vlm                 # whatever model name your endpoint expects
ANSWER_TOP_K=3
# ANSWER_MIN_SCORE=          # skip answering if the top retrieval score is below this (per-model; tune it)

# --- structured, cited answers (optional; needs an answer model) ---
ANSWER_STRUCTURED=false       # return {answer, claims:[{text, pages, confidence}]}
ANSWER_STRUCTURED_MODE=auto   # auto | json_schema | json_object | prompt
# COLPALI_QUERY_REWRITE=false # rewrite a follow-up into a standalone retrieval query using session history

# --- faithfulness check (optional; re-reads the cited pages; needs a SEPARATE judge endpoint) ---
FAITHFULNESS_GATE=off         # off | flag | withhold
# FAITHFULNESS_MIN_SCORE=0.5
JUDGE_BASE_URL=               # a DIFFERENT OpenAI-compatible vision endpoint (anti self-grading)
JUDGE_API_KEY=
JUDGE_MODEL=
JUDGE_ALLOW_SAME_ENDPOINT=false

# --- artifact (page image) storage: local (default) | s3-compatible object storage ---
STORAGE_BACKEND=local         # local | s3   (needs the [s3] extra for s3)
# STORAGE_BUCKET=
# STORAGE_ENDPOINT_URL=       # for S3-compatible object stores (MinIO / R2 / …); blank for AWS S3
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PREFIX=
# STORAGE_SERVE_MODE=proxy    # proxy (safe default) | presigned

# --- logging + per-generation run logs ---
# COLPALI_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR — INFO shows the studio step trace
# COLPALI_RUN_LOG_DIR=runs       # ON by default: each generation writes a JSON + .txt summary here
#                                # (what it studied, which rows it surfaced, what it produced, the
#                                #  refine trajectory, every constraint/repair check). Set empty to disable.

# --- web UI bind ---
COLPALI_HOST=127.0.0.1
COLPALI_PORT=8000

# --- Studio (colpali-rag studio) ---
# Reuses the answer-model settings above (VLM_BASE_URL / VLM_MODEL / VLM_API_KEY): with
# a model configured it reads datasheet pages and designs cited diagrams; without one it
# runs in demo mode (diagrams inferred from the request text). Point at a prebuilt SPA:
# STUDIO_WEB_DIST=web/dist

# --- closed-vocabulary constraint (optional; OFF by default) ---
# Constrain structured outputs to a closed vocabulary compiled from an uploaded table.
# Set CATALOG_ID_COL to the header of the id column in your uploaded file; any uploaded
# table carrying that header is compiled into the vocabulary and every proposed node is
# projected onto it (confident match -> canonical name, otherwise dropped and flagged).
# Leave CATALOG_ID_COL blank to disable — this is the default and nothing changes.
# COLPALI_CATALOG_GATE=off        # off | flag | withhold
# CATALOG_ID_COL=                 # header of the id column; blank => constraint OFF
# CATALOG_NAME_COLS=              # comma-separated alias/label columns (match-only)
# CATALOG_REQUIRED_COL=           # column marking rows that must appear in the output
# CATALOG_IFACE_COLS=             # column(s) of interface tokens; two items may connect only if they share one
# CATALOG_MATCH_THRESHOLD=0.84    # accept a fuzzy match at/above this similarity
# CATALOG_MATCH_MARGIN=0.08       # ...only if it beats the runner-up by this margin
# CATALOG_WITHHOLD_MAX_DROP=0.5   # under 'withhold', abstain if this fraction of nodes drop
# CATALOG_REPAIR_MAX=1            # times to re-prompt the model to fix catalog violations

# --- tabular display caps (the constraint channel above is never capped; these only bound
#     how much of a table is rendered into the model prompt) ---
# TABULAR_MAX_PREVIEW_ROWS=40
# TABULAR_MAX_COLS=24
# TABULAR_MAX_CELL=80
# COLPALI_TABULAR_PLAN=true      # for a sheet larger than the row budget, show the model the rows
#                                # most RELEVANT to the request (ranked) instead of just the first N
#                                # (the full sheet still reaches the catalog/constraint channel)

# --- hybrid visual + lexical retrieval (optional; OFF by default) ---
# Fuse the visual page ranking with a keyword ranking over extracted page text (Reciprocal Rank
# Fusion), so exact identifiers/codes aren't lost when a page image is blurry. Automatically
# degrades to visual-only on scanned corpora (little extractable text).
# COLPALI_HYBRID_ENABLED=false
# COLPALI_HYBRID_KAPPA=60
# COLPALI_HYBRID_FETCH=100        # candidates from each channel before fusion
# COLPALI_HYBRID_MIN_COVERAGE=0.5 # skip the lexical channel below this fraction of text-bearing pages
# COLPALI_HYBRID_NGRAM_MIN=3
# COLPALI_HYBRID_NGRAM_MAX=5
