# colpali-rag configuration. Copy to .env and edit. Everything is optional with
# sane defaults — the tool runs with none of this set.

# --- retriever (ColPali / ColVision) ---
# Any ColVision model id. colSmol-500M runs on CPU; colqwen2-v1.0 on GPU is sharper.
COLPALI_MODEL=vidore/colSmol-500M
COLPALI_DEVICE=cpu            # cpu | cuda | mps
COLPALI_BATCH_SIZE=1

# --- store ---
COLPALI_STORE=memory          # memory (zero infra) | qdrant (scale / persistence)
COLPALI_DATA_DIR=colpali_data
COLPALI_COLLECTION=documents
# For COLPALI_STORE=qdrant, point at a server; leave blank for embedded on-disk.
QDRANT_URL=
QDRANT_API_KEY=

# --- optional answer model (vendor-neutral) ---
# Point at ANY OpenAI-compatible /chat/completions vision endpoint you run
# (self-hosted vLLM / Ollama / LM Studio / TGI, or a hosted one). Leave blank to
# disable answer generation — search + heatmaps still work with no model here.
VLM_BASE_URL=                 # e.g. http://localhost:8000/v1
VLM_API_KEY=
VLM_MODEL=vlm                 # whatever model name your endpoint expects

# --- web UI bind ---
COLPALI_HOST=127.0.0.1
COLPALI_PORT=8000
