# colpali-rag configuration. Copy to .env and edit. Everything is optional with
# sane defaults — the tool runs with none of this set.

# --- retriever (ColPali / ColVision) ---
# Any ColVision model id. colSmol-500M runs on CPU; colqwen2-v1.0 on GPU is sharper.
# See docs/PIPELINE.md §11 for the clean CPU->GPU model ladder + the exclude list.
COLPALI_MODEL=vidore/colSmol-500M
COLPALI_DEVICE=cpu            # cpu | cuda | mps
COLPALI_BATCH_SIZE=1
# COLPALI_FAMILY=            # force a family (modernvbert|smol|qwen2|qwen2.5|qwen3|gemma|colpali) for a new checkpoint
COLPALI_DPI=150
COLPALI_MAX_DIM=1600

# --- store ---
COLPALI_STORE=memory          # memory (zero infra) | qdrant (scale / persistence)
COLPALI_DATA_DIR=colpali_data
COLPALI_COLLECTION=documents
# For COLPALI_STORE=qdrant, point at a server; leave blank for embedded on-disk.
QDRANT_URL=
QDRANT_API_KEY=

# --- optional reranking (config-gated OFF; needs the [rerank] extra + a GPU) ---
RERANK_ENABLED=false
RERANK_BACKEND=monoqwen       # none | monoqwen  (lightonai/MonoQwen2-VL-v0.1, Apache-2.0)
RERANK_DEVICE=cuda

# --- optional answer model (vendor-neutral) ---
# Point at ANY OpenAI-compatible /chat/completions vision endpoint you run
# (self-hosted vLLM / Ollama / LM Studio / TGI, or a hosted one). Leave blank to
# disable answer generation — search + heatmaps still work with no model here.
VLM_BASE_URL=                 # e.g. http://localhost:8000/v1
VLM_API_KEY=
VLM_MODEL=vlm                 # whatever model name your endpoint expects
ANSWER_TOP_K=3
# ANSWER_MIN_SCORE=          # skip answering if the top retrieval score is below this (per-model; tune it)

# --- structured, cited answers (optional; needs an answer model) ---
ANSWER_STRUCTURED=false       # return {answer, claims:[{text, pages, confidence}]}
ANSWER_STRUCTURED_MODE=auto   # auto | json_schema | json_object | prompt

# --- faithfulness check (optional; re-reads the cited pages; needs a SEPARATE judge endpoint) ---
FAITHFULNESS_GATE=off         # off | flag | withhold
# FAITHFULNESS_MIN_SCORE=0.5
JUDGE_BASE_URL=               # a DIFFERENT OpenAI-compatible vision endpoint (anti self-grading)
JUDGE_API_KEY=
JUDGE_MODEL=
JUDGE_ALLOW_SAME_ENDPOINT=false

# --- artifact (page image) storage: local (default) | s3-compatible object storage ---
STORAGE_BACKEND=local         # local | s3   (needs the [s3] extra for s3)
# STORAGE_BUCKET=
# STORAGE_ENDPOINT_URL=       # for S3-compatible object stores (MinIO / R2 / …); blank for AWS S3
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PREFIX=
# STORAGE_SERVE_MODE=proxy    # proxy (safe default) | presigned

# --- web UI bind ---
COLPALI_HOST=127.0.0.1
COLPALI_PORT=8000

# --- Studio (colpali-rag studio) ---
# Reuses the answer-model settings above (VLM_BASE_URL / VLM_MODEL / VLM_API_KEY): with
# a model configured it reads datasheet pages and designs cited diagrams; without one it
# runs in demo mode (diagrams inferred from the request text). Point at a prebuilt SPA:
# STUDIO_WEB_DIST=web/dist
